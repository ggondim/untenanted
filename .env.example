# --- Server ---
HTTP_PORT=3000
LOG_LEVEL=info
AUTO_MIGRATE=true

# --- Postgres (when running docker-compose.yml standalone) ---
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
POSTGRES_HOST_PORT=5432

# --- Database (used by the api) ---
# Override DB_HOST when pointing to an external postgres (e.g. Zitadel's).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=untenanted
DB_USER=untenanted
DB_PASSWORD=untenanted
DB_SSL=disable

# --- IdP (RFC-standard only) ---
IDP_JWKS_URI=http://localhost:8080/oauth/v2/keys
IDP_ISSUER=http://localhost:8080
IDP_AUDIENCE=platform-api
IDP_TOKEN_ENDPOINT=http://localhost:8080/oauth/v2/token
IDP_CLIENT_ID=untenanted-api
IDP_CLIENT_SECRET=change-me

# --- Claim names (configurable per IdP vocabulary) ---
CLAIM_ORG_ID=org_id
CLAIM_TIDS=tids
CLAIM_SCOPE=scope
CLAIM_SUBJECT=sub

# --- Internal auth secrets (shared with the IdP adapter) ---
INTERNAL_AUTH_SECRET=change-me-internal
WEBHOOK_AUTH_SECRET=change-me-webhook

# --- API host port ---
API_HOST_PORT=3000
